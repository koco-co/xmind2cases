# 语言检测：将模板文件识别为 Python
*.html linguist-language=Python
*.css linguist-language=Python
*.js linguist-language=Python

# 统一换行符：文本文件使用 LF
* text=auto eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf

# Shell 脚本使用 LF 且可执行
*.sh text eol=lf
init.sh text eol=lf

# PowerShell 脚本使用 LF（现代 PowerShell 支持）
*.ps1 text eol=lf
init.ps1 text eol=lf

# Python 文件使用 LF
*.py text eol=lf

# 配置文件使用 LF
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# XMind 文件（二进制）
*.xmind binary

# 数据库文件（二进制）
*.db binary
*.sqlite binary

# 图片文件（二进制）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# 字体文件（二进制）
*.woff binary
*.woff2 binary
*.ttf binary
